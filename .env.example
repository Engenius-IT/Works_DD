# ===================================
# JobSabuy Environment Variables
# ===================================

# --- Database (Supabase Postgres) ---
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=jobsabuy-assets

# --- Legacy Database Export (MySQL) ---
LEGACY_MYSQL_URL=mysql://root:password@localhost:3306/jobsabuy

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Search Engine (Meilisearch) ---
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=masterKey123

# --- File Storage (S3 / Cloud Storage) ---
S3_BUCKET=jobsabuy-uploads
S3_REGION=ap-southeast-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Auth ---
NEXTAUTH_SECRET=your-secret-key-change-me
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=your-jwt-secret-change-me
JWT_EXPIRES_IN=7d

# --- OAuth Providers ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
GEMINI_API_KEY=

# --- App ---
NEXT_PUBLIC_API_URL=https://jobsabuyapi-production-2b0d.up.railway.app/api/v1
API_URL=http://localhost:3001
NODE_ENV=development
PORT=3001
