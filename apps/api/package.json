{
  "name": "@jobsabuy/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "clean": "rimraf dist .turbo",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "data:export:dry-run": "node scripts/export-mysql-to-json.mjs --json",
    "data:export:apply": "node scripts/export-mysql-to-json.mjs --apply --json",
    "data:migration:dry-run": "node scripts/import-json-to-supabase.mjs --json",
    "data:migration:apply": "node scripts/import-json-to-supabase.mjs --apply --json",
    "data:migration:verify": "node scripts/verify-supabase-data.mjs --json --strict",
    "storage:backfill:dry-run": "node scripts/backfill-legacy-storage-urls.mjs --json",
    "storage:backfill:apply": "node scripts/backfill-legacy-storage-urls.mjs --apply --json"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@google/generative-ai": "^0.24.1",
    "@jobsabuy/shared-types": "workspace:*",
    "@jobsabuy/validators": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^8.0.0",
    "@prisma/client": "5.22.0",
    "bcryptjs": "^3.0.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "express": "^4.18.0",
    "multer": "^2.0.2",
    "mysql2": "^3.11.3",
    "pdf-parse": "^1.1.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/bcryptjs": "^2.4.0",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.6.0",
    "@types/pdf-parse": "^1.1.4",
    "eslint": "^9.0.0",
    "prisma": "5.22.0",
    "rimraf": "^6.0.0",
    "source-map-support": "^0.5.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0"
  }
}