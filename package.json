{
  "name": "jobdd",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "start": "turbo run start",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:migrate": "bun run --filter @worksdd/api prisma migrate dev",
    "db:seed": "bun run --filter @worksdd/api prisma db seed",
    "db:studio": "bun run --filter @worksdd/api prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "clean": "turbo run clean && rimraf node_modules",
    "build:api": "cd apps/api && npx prisma generate && npx tsc -p tsconfig.json",
    "build:web": "cd apps/web && next build"
  },
  "devDependencies": {
    "@prisma/client": "5.22.0",
    "next": "^15.2.0",
    "prettier": "^3.8.1",
    "prisma": "5.22.0",
    "rimraf": "^6.1.3",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.8",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@nestjs/schedule": "^6.1.3",
    "@react-pdf/renderer": "^4.5.1",
    "ajv": "^8.20.0",
    "axios": "^1.17.0",
    "resend": "^6.12.4",
    "web": "^0.0.2"
  }
}